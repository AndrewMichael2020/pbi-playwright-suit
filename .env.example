# Copy this file to .env and fill in only what you need.
# Interactive `npm run setup` can work without .env via device-flow sign-in.
# These values are mainly for non-interactive report selection and local overrides.
# Fully non-interactive runs still require a valid MSAL token cache.

# Azure AD / Power BI auth
# CLIENT_ID=
# TENANT_ID=
PBI_ENVIRONMENT=Public
PBI_TOKEN_CACHE_FILE=playwright/.auth/msal-device-token-cache.json

# Local browser selection for enterprise visual checks
PBI_BROWSER_CHANNEL=chrome

# Non-interactive setup target selection
# PBI_WORKSPACE_NAME=
# PBI_REPORT_NAME=
# PBI_DATASET_NAME=
# PBI_PAGE_NAME=

# Optional run label for test-archive/<run-id>
# PBI_RUN_ID=
