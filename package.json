{
  "name": "pbi-playwright-suit",
  "version": "1.0.0",
  "description": "Lightweight Playwright-based Power BI workspace quality suite",
  "scripts": {
    "clean": "node -e \"const fs=require('fs');['playwright/config/enterprise.generated.json','playwright/config/enterprise.focus.json'].forEach(f=>{try{fs.rmSync(f);console.log('removed '+f);}catch{}});try{fs.rmSync('playwright/.auth',{recursive:true,force:true});console.log('removed playwright/.auth');}catch{}\"",
    "install:browsers": "playwright install",
    "typecheck": "tsc --noEmit",
    "test": "playwright test --project=dry-run",
    "test:enterprise": "playwright test --project=enterprise",
    "test:full": "playwright test --project=dry-run --project=enterprise",
    "show-report": "node -e \"const fs=require('fs'),p='test-archive';const runs=fs.readdirSync(p).filter(d=>fs.statSync(p+'/'+d).isDirectory()).sort();const latest=runs[runs.length-1];if(!latest){console.error('No runs in test-archive/');process.exit(1);}require('child_process').spawn('npx',['playwright','show-report',p+'/'+latest+'/html-report'],{stdio:'inherit',shell:true});\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AndrewMichael2020/pbi-playwright-suit.git"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/AndrewMichael2020/pbi-playwright-suit/issues"
  },
  "homepage": "https://github.com/AndrewMichael2020/pbi-playwright-suit#readme",
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "powerbi-client": "^2.23.10",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@azure/msal-node": "^5.2.2"
  }
}
